# backend/.env.example
# ─────────────────────────────────────────────────────────────────
# LLM PROVIDER — pick one block, comment out the others
# ─────────────────────────────────────────────────────────────────

# ── Option A: HuggingFace (current default) ───────────────────────
LLM_PROVIDER=huggingface
HUGGINGFACEHUB_API_TOKEN=hf_your_token_here
# HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct   # optional override

# ── Option B: OpenAI ──────────────────────────────────────────────
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your_key_here
# OPENAI_MODEL=gpt-4o                                    # optional override

# ── Option C: Groq (free tier available, very fast) ───────────────
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_your_key_here
# GROQ_MODEL=llama-3.3-70b-versatile                     # optional override

# ─────────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:password@localhost:5432/database
